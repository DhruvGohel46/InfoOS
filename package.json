{
  "name": "infobill",
  "version": "1.0.1",
  "main": "electron/main.js",
  "scripts": {
    "start": "set HOST=127.0.0.1 && set BROWSER=none && npm start --prefix frontend",
    "build": "cd frontend && npm run build",
    "test": "cd frontend && npm test",
    "test:e2e": "playwright test",
    "eject": "cd frontend && npm run eject",
    "electron": "electron .",
    "electron-dev": "concurrently \"npm start\" \"wait-on http://localhost:3050 && electron .\"",
    "build:backend": "cd backend && pyinstaller backend.spec",
    "dist": "npm run build && npm run build:backend && electron-builder",
    "preelectron-pack": "npm run build",
    "backend": "cd backend && python app.py",
    "dev": "npm run electron-dev",
    "build-all": "npm run dist",
    "release": "electron-builder --publish always"
  },
  "dependencies": {
    "electron-updater": "^6.7.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "concurrently": "^8.2.2",
    "electron": "^28.3.3",
    "electron-builder": "^24.9.1",
    "wait-on": "^7.2.0",
    "serve": "^14.2.0",
    "yaml": "2.8.4"
  },
  "build": {
    "appId": "com.burgerbhau.infobill",
    "productName": "InfoBill",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "frontend/build/**/*",
      "electron/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "backend/dist/backend",
        "to": "backend"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "electron/assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "InfoBill"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "DhruvGohel46",
        "repo": "Rebill"
      }
    ]
  }
}
