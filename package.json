{
  "//_installer_optimization_notes": [
    "The following unnecessary files can be excluded from packaging to optimize installer size:",
    "1. frontend/build/static/js/*.map - JS Source maps (debug only)",
    "2. frontend/build/static/css/*.map - CSS Source maps (debug only)",
    "3. electron/assets/generate_installer_assets.py - Python utility script used to generate assets",
    "4. backend/build/ - PyInstaller intermediate files and caches",
    "5. backend/.venv/ - Python virtual environment folder (the executable packages dependencies, so the venv itself is dev-only)",
    "To automatically exclude them, add glob patterns to 'build.files' or 'build.extraResources' exclusions."
  ],
  "name": "infoos",
  "version": "30.2.10",
  "description": "Product Sales Management Application",
  "author": "InfoOS Private Limited",
  "main": "electron/main.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/DhruvGohel46/Rebill.git"
  },
  "scripts": {
    "start": "set HOST=127.0.0.1 && set BROWSER=none && npm start --prefix frontend",
    "build": "cd frontend && npm run build",
    "test": "cd frontend && npm test",
    "test:e2e": "playwright test",
    "eject": "cd frontend && npm run eject",
    "electron": "electron .",
    "electron-dev": "concurrently \"npm start\" \"wait-on http://localhost:3050 && electron .\"",
    "electron-debug": "electron . --debug",
    "build:backend": "cd backend && call .venv\\Scripts\\pyinstaller --noconfirm backend.spec",
    "dist": "npm run build && npm run build:backend && electron-builder",
    "preelectron-pack": "npm run build",
    "backend": "cd backend && python app.py",
    "dev": "npm run electron-dev",
    "build-all": "npm run dist",
    "release": "electron-builder --publish always"
  },
  "dependencies": {
    "electron-updater": "^6.7.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "concurrently": "^8.2.1",
    "electron": "^28.3.3",
    "electron-builder": "^24.9.1",
    "serve": "^14.2.0",
    "wait-on": "^7.2.0",
    "yaml": "2.8.4"
  },
  "build": {
    "appId": "com.burgerbhau.infoos",
    "productName": "InfoOS",
    "copyright": "Copyright © 2026 InfoOS Private Limited. All rights reserved.",
    "compression": "maximum",
    "artifactName": "${productName} Setup.${ext}",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "frontend/build/**/*",
      "electron/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "backend/dist/backend",
        "to": "backend"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "electron/assets/icon.ico",
      "publisherName": "InfoOS Private Limited"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "InfoOS",
      "installerIcon": "electron/assets/icon.ico",
      "uninstallerIcon": "electron/assets/icon.ico",
      "installerHeader": "electron/assets/installerHeader.bmp",
      "installerHeaderIcon": "electron/assets/icon.ico",
      "installerSidebar": "electron/assets/installerSidebar.bmp",
      "uninstallerSidebar": "electron/assets/uninstallerSidebar.bmp",
      "license": "electron/assets/license.txt",
      "runAfterFinish": true,
      "uninstallDisplayName": "InfoOS Uninstaller",
      "differentialPackage": true
    },
    "publish": [
      {
        "provider": "github",
        "owner": "DhruvGohel46",
        "repo": "Rebill",
        "releaseType": "release"
      }
    ]
  }
}
